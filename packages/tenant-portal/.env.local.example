# Copy to .env.local for local development. Production values live in
# Portainer stack env, not in this file.

# --- NextAuth ---
# In local dev this is http://localhost:3000. In staging/prod this is the
# externally-resolvable URL of this service.
NEXTAUTH_URL=http://localhost:3000
# Long random secret used to sign the next-auth JWT cookie. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Keycloak (OIDC) ---
# Reuses the existing preaa-staging client. Important: the Keycloak client's
# "Valid Redirect URIs" must include `<NEXTAUTH_URL>/api/auth/callback/keycloak`
# AND the client must have a "realm roles" mapper so `realm_access.roles`
# is included in the access token.
KEYCLOAK_URL=https://damplab-keycloak.sail.codes
KEYCLOAK_REALM=preaa
KEYCLOAK_CLIENT_ID=preaa-staging
KEYCLOAK_CLIENT_SECRET=

# --- Keycloak admin REST API (used by the provisioning saga in upcoming
# commits to create users + roles per tenant). This is a SEPARATE Keycloak
# client from the user-auth one above: confidential, service-accounts only,
# with realm-management roles attached. Created out-of-band; client ID is
# pinned by convention. ---
KEYCLOAK_ADMIN_CLIENT_ID=tenant-portal-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=

# --- Postgres (used by /api/tenants/* and the provisioning saga) ---
# Local dev needs a Postgres reachable. If you've got the staging stack
# running locally, point at that. Or run a dedicated one:
#   docker run -d --name tp-pg -p 5432:5432 \
#     -e POSTGRES_USER=psql -e POSTGRES_PASSWORD=temp-password \
#     -e POSTGRES_DB=tenant_portal postgres:16
# Schema is auto-created on first connect (idempotent CREATE TABLE IF NOT
# EXISTS). To run it by hand instead:
#   psql "$TENANT_PORTAL_DATABASE_URL" -f src/app/lib/db/migrations/0001_init.sql
TENANT_PORTAL_DATABASE_URL=postgres://psql:temp-password@localhost:5432/tenant_portal

# AES-256-GCM key for encrypting tenant secrets at rest in Postgres.
# 32 bytes hex (64 chars). Generate with: openssl rand -hex 32
TENANT_PORTAL_ENCRYPTION_KEY=

# --- Langflow (used by ProvisioningService to create per-tenant user +
# flow + API key). LANGFLOW_ADMIN_API_KEY should be a long-lived API key
# on a Langflow superuser, set via the Langflow UI → Settings → API Keys.
# For local dev pointed at staging: https://langflow-preaa-staging.sail.codes ---
LANGFLOW_API_BASE=http://localhost:7860
LANGFLOW_ADMIN_API_KEY=

# --- Langfuse (used by ProvisioningService to create per-tenant project +
# API key pair). LANGFUSE_ADMIN_API_KEY needs an org-admin scoped key from
# Langfuse Org Settings → API Keys. LANGFUSE_ADMIN_ORG_ID is which org to
# provision projects in. ---
LANGFUSE_API_BASE=http://localhost:3000
LANGFUSE_ADMIN_API_KEY=
LANGFUSE_ADMIN_ORG_ID=

# --- LiteLLM (used by ProvisioningService to mint per-tenant virtual keys).
# Reuses the existing master key. ---
LITELLM_API_BASE=http://localhost:4000
LITELLM_MASTER_KEY=
