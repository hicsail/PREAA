LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=<LITELLM_KEY>
MONGODB_URI=mongodb://127.0.0.1:27017/preaa-admin

# Langflow Configuration (server-side)
LANGFLOW_BASE_URL=http://localhost:7860
LANGFLOW_SUPERUSER=langflow
LANGFLOW_SUPERUSER_PASSWORD=langflow

# Public URLs (exposed to the browser)
NEXT_PUBLIC_LANGFLOW_URL=http://localhost:7860
NEXT_PUBLIC_EMBEDDED_CHAT_URL=http://localhost:5173

# CORS Configuration
# Comma-separated list of allowed origins for embedded chat client
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://example.com
# If not set, defaults to '*' (allows all origins - use only in development)
ALLOWED_ORIGINS=*

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl_rand_base64_32

# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=myrealm
KEYCLOAK_CLIENT_ID=my-nextjs-client
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret_here
